# ── Servidor ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001   # cambiar por tu dominio en producción

# ── JWT — generá con: openssl rand -base64 64 ─────────────────────
JWT_SECRET=cambia_esto_en_produccion
JWT_EXPIRES_IN=7d

# ── Supabase ──────────────────────────────────────────────────────
# Obtenés estas en: supabase.com → tu proyecto → Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # NUNCA exponer al frontend
SUPABASE_ANON_KEY=eyJ...

# ── Twilio MASTER ACCOUNT ─────────────────────────────────────────
# La cuenta TUYA (de Debtflow, no del usuario)
# twilio.com → Console → Account SID + Auth Token
TWILIO_MASTER_ACCOUNT_SID=ACxxxx
TWILIO_MASTER_AUTH_TOKEN=xxxx
TWILIO_PHONE_AREA_CODE=1           # código de área para comprar números

# ── Vapi ─────────────────────────────────────────────────────────
# vapi.ai → Dashboard → API Keys
VAPI_API_KEY=xxxx
VAPI_WEBHOOK_SECRET=xxxx           # crealo vos, se configura en Vapi dashboard

# ── Encriptación (para guardar tokens de Twilio en la DB) ─────────
# Generá con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=xxxx
